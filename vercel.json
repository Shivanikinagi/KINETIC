{
  "version": 2,
  "name": "kinetic-marketplace",
  "builds": [
    {
      "src": "web/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "web/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web/server.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
