{
  "version": 2,
  "name": "kinetic-marketplace",
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/agent_bridge.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/agent/(.*)",
      "dest": "api/agent_bridge.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/main.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "web/static/$1"
    },
    {
      "src": "/(.*\\.(html|css|js|png|jpg|svg|ico))",
      "dest": "web/$1"
    },
    {
      "src": "/",
      "dest": "web/index.html"
    }
  ],
  "env": {
    "ALGORAND_NETWORK": "testnet",
    "ALGOD_URL": "https://testnet-api.algonode.cloud",
    "INDEXER_URL": "https://testnet-idx.algonode.cloud",
    "ALGOD_TOKEN": "",
    "JOB_PRICE_PER_TOKEN_MICROALGO": "100",
    "AGENT_DAILY_BUDGET_MICROALGO": "5000000"
  },
  "regions": ["iad1"],
  "framework": null
}
